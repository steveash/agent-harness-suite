# Agent Harness Suite - Environment Configuration
# Copy to .env and fill in required values

# === Required ===

# Anthropic API key (for Claude Agent SDK harness)
ANTHROPIC_API_KEY=

# GitHub personal access token (for repo access and Copilot SDK)
GITHUB_TOKEN=

# === Optional ===

# Default model for Claude harness (default: claude-sonnet-4-20250514)
# AHS_CLAUDE_MODEL=claude-sonnet-4-20250514

# Log level (default: INFO)
# AHS_LOG_LEVEL=INFO

# Output directory for benchmark results (default: ./results)
# AHS_RESULTS_DIR=./results
